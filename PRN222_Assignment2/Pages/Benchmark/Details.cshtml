@page "{experimentId:int}"
@model PRN222_Assignment2.Pages.Benchmark.DetailsModel
@{
    ViewData["Title"] = "Chi tiết Benchmark";
    ViewData["ActivePage"] = "Benchmark";
}

<div class="page-header">
    <div style="display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:1rem;">
        <div>
            <h1>📈 Kết quả Benchmark</h1>
            <p>Chi tiết kết quả đánh giá (Faithfulness & Relevance)</p>
        </div>
        <a href="/Benchmark?subjectId=@Model.SubjectId" class="btn btn-secondary">← Trở về</a>
    </div>
</div>

<div class="grid-2">
    <div class="card">
        <h3 style="margin-bottom:1rem; color:#fff;">Tóm tắt Kết quả</h3>
        @if (Model.Results.Any())
        {
            var avgF = Model.Results.Average(r => (double?)r.FaithfulnessScore) ?? 0;
            var avgR = Model.Results.Average(r => (double?)r.RelevanceScore) ?? 0;
            var avgLat = Model.Results.Average(r => (double?)r.LatencyMs) ?? 0;
            <div style="display:flex; gap:2rem;">
                <div>
                    <div style="color:var(--text-muted); font-size:0.8rem;">Faithfulness</div>
                    <div style="font-size:2rem; font-weight:700; color:#6ee7b7;">@avgF.ToString("P1")</div>
                </div>
                <div>
                    <div style="color:var(--text-muted); font-size:0.8rem;">Relevance</div>
                    <div style="font-size:2rem; font-weight:700; color:#93c5fd;">@avgR.ToString("P1")</div>
                </div>
                <div>
                    <div style="color:var(--text-muted); font-size:0.8rem;">Avg Latency</div>
                    <div style="font-size:2rem; font-weight:700; color:#fff;">@avgLat.ToString("F0") ms</div>
                </div>
            </div>
        }
        else
        {
            <p style="color:var(--text-muted);">Experiment chưa được chạy hoặc không có dữ liệu.</p>
        }
    </div>
</div>

<h3 style="margin-top:2rem; margin-bottom:1rem; color:#fff;">Chi tiết Test Cases</h3>
<div style="display:flex; flex-direction:column; gap:1rem;">
    @foreach (var result in Model.Results)
    {
        <div class="card" style="margin-bottom:0;">
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:1.5rem;">
                <div>
                    <div style="font-weight:600; color:var(--text-muted); margin-bottom:0.5rem; font-size:0.8rem;">Q: @result.Question</div>
                    <div style="font-size:0.875rem; color:#93c5fd; background:rgba(59,130,246,0.1); padding:0.75rem; border-radius:8px; border:1px solid rgba(59,130,246,0.2);">
                        <strong>Expected:</strong><br/> @result.ExpectedAnswer
                    </div>
                </div>
                <div>
                    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:0.5rem;">
                        <div style="font-size:0.8rem; font-weight:600; color:var(--text-muted);">AI Generated Answer</div>
                        <div style="display:flex; gap:0.5rem; font-size:0.75rem;">
                            <span style="color:#6ee7b7;">F: @(result.FaithfulnessScore?.ToString("P1") ?? "-")</span>
                            <span style="color:#93c5fd;">R: @(result.RelevanceScore?.ToString("P1") ?? "-")</span>
                            <span style="color:var(--text-muted);">⏱️ @result.LatencyMs ms</span>
                        </div>
                    </div>
                    
                    @if (!string.IsNullOrEmpty(result.ErrorMessage))
                    {
                        <div style="font-size:0.875rem; color:#fca5a5; background:rgba(239,68,68,0.1); padding:0.75rem; border-radius:8px; border:1px solid rgba(239,68,68,0.2);">
                            <strong>Lỗi:</strong> @result.ErrorMessage
                        </div>
                    }
                    else
                    {
                        <div style="font-size:0.875rem; color:#fff; background:var(--surface2); padding:0.75rem; border-radius:8px; border:1px solid var(--border);">
                            @result.GeneratedAnswer
                        </div>
                    }
                </div>
            </div>
        </div>
    }
    @if (!Model.Results.Any())
    {
        <div class="card" style="text-align:center; padding:3rem; color:var(--text-muted);">
            Chưa có kết quả. Bạn cần thêm Test Case và chạy (Run) Experiment.
        </div>
    }
</div>

<!-- Add Test Case -->
<div class="card" style="margin-top:2rem;">
    <h3 style="margin-bottom:1rem; color:#fff;">+ Thêm Test Case Mới</h3>
    <form method="post" asp-page-handler="AddTestCase">
        @Html.AntiForgeryToken()
        <div class="grid-2">
            <div class="form-group">
                <label class="form-label">Câu hỏi (Question)</label>
                <textarea name="TestCaseInput.Question" class="form-control" rows="3" required></textarea>
            </div>
            <div class="form-group">
                <label class="form-label">Câu trả lời mẫu (Expected Answer)</label>
                <textarea name="TestCaseInput.ExpectedAnswer" class="form-control" rows="3" required></textarea>
            </div>
        </div>
        <div style="display:flex; justify-content:flex-end;">
            <button type="submit" class="btn btn-primary">+ Thêm</button>
        </div>
    </form>
</div>
