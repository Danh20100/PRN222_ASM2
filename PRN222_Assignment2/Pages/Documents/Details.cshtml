@page "{id:int}"
@model PRN222_Assignment2.Pages.Documents.DetailsModel
@{
    ViewData["Title"] = "Chi tiết Tài liệu";
}

<div class="page-header">
    <div style="display:flex; justify-content:space-between; align-items:center;">
        <h1>Chi tiết Document: @(Model.Document?.OriginalFileName ?? "N/A")</h1>
        <a href="/Documents" class="btn btn-secondary">← Quay lại</a>
    </div>
</div>

@if (Model.Document == null)
{
    <div class="alert alert-error">Không tìm thấy tài liệu.</div>
}
else
{
    <div class="card" style="margin-bottom:1rem;">
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem;">
            <div>
                <p><strong>Môn học:</strong> @Model.Document.SubjectName</p>
                <p><strong>Chapter:</strong> @Model.Document.ChapterName</p>
                <p><strong>Người upload:</strong> @Model.Document.UploadedByFullName</p>
            </div>
            <div>
                <p><strong>Trạng thái:</strong> 
                    <span class="badge badge-@(Model.Document.Status.ToLower() == "indexed" ? "indexed" : Model.Document.Status.ToLower() == "failed" ? "failed" : "pending")">
                        @Model.Document.Status
                    </span>
                </p>
                <p><strong>Tổng số chunks:</strong> @Model.Document.TotalChunks</p>
                <p><strong>Upload lúc:</strong> @Model.Document.UploadedAt.ToString("dd/MM/yyyy HH:mm")</p>
            </div>
        </div>
        @if (!string.IsNullOrEmpty(Model.Document.ErrorMessage))
        {
            <div class="alert alert-error" style="margin-top:0.75rem; margin-bottom:0;">
                <strong>Lỗi:</strong> @Model.Document.ErrorMessage
            </div>
        }
    </div>

    <h3 style="margin-bottom:0.75rem;">Danh sách Chunks</h3>
    <div class="card" style="padding:0;">
        <table>
            <thead>
                <tr>
                    <th style="width: 5%">#</th>
                    <th style="width: 10%">Số chữ</th>
                    <th>Nội dung Chunk</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Chunks.Any())
                {
                    foreach (var chunk in Model.Chunks)
                    {
                        <tr>
                            <td>@chunk.ChunkIndex</td>
                            <td>@chunk.TokenCount</td>
                            <td>
                                <div style="max-height: 120px; overflow-y: auto; white-space: pre-wrap; font-size: 0.85rem; word-break: break-word; padding-right: 8px;">
                                    @chunk.ChunkText
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="3" style="text-align:center; color:#6c757d; padding:2rem;">Chưa có dữ liệu chunk nào được tạo.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
