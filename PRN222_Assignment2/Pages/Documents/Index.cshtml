@page
@model PRN222_Assignment2.Pages.Documents.IndexModel
@{
    ViewData["Title"] = "Tài liệu";
    ViewData["ActivePage"] = "Documents";
}

<div class="page-header">
    <div style="display:flex; justify-content:space-between; align-items:center; width:100%; flex-wrap:wrap; gap:1rem;">
        <div>
            <h1 style="font-size:1.8rem; font-weight:800; color:#3498db; text-transform:uppercase; margin-bottom:0.5rem;">LỊCH SỬ TÀI LIỆU ĐÃ TẢI LÊN</h1>
            <p style="color:#6c757d; font-size:0.95rem;">Danh sách tất cả các tài liệu do bạn đăng tải. Lịch sử này được giữ nguyên ngay cả khi môn học được chuyển cho giảng viên khác phụ trách.</p>
        </div>
        @if (User.IsInRole("Admin"))
        {
            <div class="alert alert-info" style="margin-bottom:0; padding:0.35rem 0.75rem;">
                <span style="font-size:0.8rem;">Admin chỉ có quyền xem tài liệu và Re-Index.</span>
            </div>
        }
    </div>
</div>

@if (TempData["Success"] != null)
{ <div class="alert alert-success">@TempData["Success"]</div> }
@if (TempData["Error"] != null)
{ <div class="alert alert-error">@TempData["Error"]</div> }

<!-- Filter Bar -->
<div class="card" style="padding:1rem; margin-bottom:1.5rem; border-radius:8px; box-shadow:0 4px 6px rgba(0,0,0,0.02);">
    <form method="get" style="display:flex; gap:1rem; align-items:center; flex-wrap:wrap;">
        <select name="subjectId" class="form-control" style="width:250px;" onchange="this.form.submit()">
            <option value="">-- Tất cả môn học --</option>
            @foreach (var s in Model.Subjects)
            {
                <option value="@s.SubjectId" selected="@(Model.SelectedSubjectId == s.SubjectId)">
                    @s.SubjectCode — @s.SubjectName
                </option>
            }
        </select>
        <select name="status" class="form-control" style="width:200px;" onchange="this.form.submit()">
            <option value="">-- Tất cả trạng thái --</option>
            <option value="Pending" selected="@(Model.SelectedStatus == "Pending")">Pending</option>
            <option value="Processing" selected="@(Model.SelectedStatus == "Processing")">Processing</option>
            <option value="Indexed" selected="@(Model.SelectedStatus == "Indexed")">Indexed</option>
            <option value="Failed" selected="@(Model.SelectedStatus == "Failed")">Failed</option>
        </select>
    </form>
</div>

<!-- Documents Table -->
<div class="card" style="padding:0; border-radius:8px; overflow:hidden; box-shadow:0 4px 6px rgba(0,0,0,0.02);">
    <table style="width:100%; border-collapse:collapse; background:#fff;">
        <thead>
            <tr style="background:#f8f9fa; border-bottom:2px solid #dee2e6;">
                <th style="padding:1rem; text-align:left; font-weight:800; font-size:0.85rem; color:#333; text-transform:uppercase;">Tên tài liệu</th>
                <th style="padding:1rem; text-align:left; font-weight:800; font-size:0.85rem; color:#333; text-transform:uppercase;">Môn học</th>
                <th style="padding:1rem; text-align:left; font-weight:800; font-size:0.85rem; color:#333; text-transform:uppercase;">Chương</th>
                <th style="padding:1rem; text-align:left; font-weight:800; font-size:0.85rem; color:#333; text-transform:uppercase;">Người đăng</th>
                <th style="padding:1rem; text-align:left; font-weight:800; font-size:0.85rem; color:#333; text-transform:uppercase;">Ngày đăng</th>
                <th style="padding:1rem; text-align:center; font-weight:800; font-size:0.85rem; color:#333; text-transform:uppercase;">Loại</th>
                <th style="padding:1rem; text-align:center; font-weight:800; font-size:0.85rem; color:#333; text-transform:uppercase;">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var doc in Model.Documents)
            {
                <tr style="border-bottom:1px solid #dee2e6; transition:background-color 0.2s;" onmouseover="this.style.backgroundColor='#f8f9fa'" onmouseout="this.style.backgroundColor='transparent'">
                    <td style="padding:1rem; font-weight:700; color:#333;">@doc.OriginalFileName</td>
                    <td style="padding:1rem; color:#6c757d; font-weight:600;">@doc.SubjectName</td>
                    <td style="padding:1rem; color:#6c757d;">@doc.ChapterName</td>
                    <td style="padding:1rem; color:#3498db; font-weight:600;">@doc.UploadedByFullName</td>
                    <td style="padding:1rem; color:#6c757d;">
                        <div style="font-weight:600; color:#333;">@doc.UploadedAt.ToString("dd/MM/yyyy")</div>
                        <div style="font-size:0.8rem;">@doc.UploadedAt.ToString("HH:mm")</div>
                    </td>
                    <td style="padding:1rem; text-align:center;">
                        <span style="color:#0d6efd; font-weight:800;">@doc.FileType?.ToUpper()</span>
                    </td>
                    <td style="padding:1rem; text-align:center;">
                        <a href="/Documents/View/@doc.DocumentId" class="btn" style="background:#e83e8c; color:#fff; font-weight:800; padding:0.4rem 1rem; border-radius:4px; text-decoration:none;">📥 TẢI XUỐNG</a>
                    </td>
                </tr>
            }
            @if (!Model.Documents.Any())
            {
                <tr>
                    <td colspan="7" style="text-align:center; padding:3rem; color:#6c757d;">
                        <div style="font-size:2rem; margin-bottom:1rem;">📄</div>
                        Không có tài liệu nào.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
<script>
let reloadScheduled = false;
function scheduleReload() {
    if (reloadScheduled) return;
    reloadScheduled = true;
    setTimeout(() => location.reload(), 400);
}

const documentConnection = new signalR.HubConnectionBuilder()
    .withUrl("/documentHub")
    .build();

documentConnection.on("ReceiveDocumentUpdate", function (action, payload) {
    console.log("Document SignalR:", action, payload);
    scheduleReload();
});

documentConnection.start().catch(function (err) {
    console.error("Document SignalR Error:", err.toString());
});
</script>
}

@functions {
    string FormatFileSize(long bytes)
    {
        if (bytes < 1024) return bytes + " B";
        if (bytes < 1048576) return (bytes / 1024.0).ToString("F1") + " KB";
        return (bytes / 1048576.0).ToString("F1") + " MB";
    }
}
