<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — RAG LMS</title>
    <meta name="description" content="@(ViewData["Description"] ?? "RAG-powered Learning Management System")" />
    <link rel="stylesheet" href="~/css/site.css" />
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f5f5f5;
            color: #333;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        a { color: #0d6efd; text-decoration: none; }
        a:hover { text-decoration: underline; }

        /* ── Navbar ─────────────────────────────── */
        .navbar {
            background-color: #fff;
            border-bottom: 1px solid #dee2e6;
            padding: 0 1rem;
            display: flex;
            align-items: center;
            height: 56px;
        }

        .navbar-brand {
            font-weight: 700;
            font-size: 1.1rem;
            color: #333;
            margin-right: 2rem;
            text-decoration: none;
        }

        .navbar-brand:hover { text-decoration: none; color: #0d6efd; }

        .navbar-nav {
            display: flex;
            align-items: center;
            gap: 0.25rem;
            list-style: none;
            flex: 1;
        }

        .nav-link {
            display: inline-block;
            padding: 0.5rem 0.75rem;
            color: #555;
            font-size: 0.875rem;
            border-radius: 4px;
            text-decoration: none;
        }

        .nav-link:hover { background-color: #e9ecef; color: #333; text-decoration: none; }
        .nav-link.active { background-color: #0d6efd; color: #fff; }
        .nav-link.active:hover { background-color: #0b5ed7; }

        .nav-separator {
            width: 1px;
            height: 20px;
            background-color: #dee2e6;
            margin: 0 0.5rem;
        }

        .navbar-right {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            margin-left: auto;
        }

        .user-info-text {
            font-size: 0.8rem;
            color: #666;
        }

        .user-info-text strong {
            color: #333;
        }

        .badge-role {
            display: inline-block;
            padding: 0.15rem 0.5rem;
            border-radius: 3px;
            font-size: 0.7rem;
            font-weight: 600;
        }

        .badge-admin { background-color: #f8d7da; color: #842029; }
        .badge-teacher { background-color: #cfe2ff; color: #084298; }
        .badge-student { background-color: #d1e7dd; color: #0f5132; }

        .btn-logout {
            padding: 0.3rem 0.75rem;
            background-color: #dc3545;
            color: #fff;
            border: none;
            border-radius: 4px;
            font-size: 0.8rem;
            font-family: inherit;
            cursor: pointer;
        }

        .btn-logout:hover { background-color: #bb2d3b; }

        /* ── Main Content ─────────────────────────── */
        .main-content {
            flex: 1;
            padding: 1.5rem 2rem;
            max-width: 1200px;
            margin: 0 auto;
            width: 100%;
        }

        /* ── Admin Frame ─────────────────────────────── */
        .admin-frame {
            min-height: 100vh;
            display: grid;
            grid-template-columns: 240px 1fr;
            background-color: #f4f6f8;
        }

        .admin-sidebar {
            background: #fff;
            border-right: 1px solid #dee2e6;
            padding: 1.5rem 1rem;
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        .admin-brand {
            font-weight: 800;
            color: #111;
            font-size: 1.4rem;
            margin-bottom: 1.5rem;
            padding: 0.5rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .admin-brand:hover {
            color: #111;
            text-decoration: none;
        }

        .admin-menu-label {
            font-size: 0.75rem;
            font-weight: 700;
            color: #6c757d;
            margin-top: 1rem;
            margin-bottom: 0.5rem;
            padding-left: 0.5rem;
            letter-spacing: 0.5px;
        }

        .admin-menu {
            display: flex;
            flex-direction: column;
            gap: 0.25rem;
        }

        .admin-menu-link {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 0.75rem 1rem;
            border-radius: 6px;
            font-weight: 700;
            font-size: 0.9rem;
            color: #333;
            border: none;
            background: transparent;
            cursor: pointer;
            text-decoration: none;
            transition: background 0.15s, color 0.15s;
        }

        .admin-menu-link:hover {
            background: #f0f0f0;
            text-decoration: none;
            color: #e83e8c;
        }

        .admin-menu-link.active {
            background: #e83e8c;
            color: #fff;
        }

        .admin-menu-link.active:hover {
            background: #d63384;
            color: #fff;
        }

        .admin-user-box {
            margin-top: auto;
            border: 1px solid #dee2e6;
            border-radius: 6px;
            padding: 0.75rem;
            display: flex;
            align-items: center;
            gap: 0.75rem;
            background: #fff;
            margin-bottom: 0.5rem;
        }

        .admin-user-avatar {
            width: 36px;
            height: 36px;
            background: #0d47a1;
            color: white;
            border-radius: 4px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
        }

        .admin-user-info {
            display: flex;
            flex-direction: column;
        }
        
        .admin-user-info strong {
            font-size: 0.9rem;
            color: #333;
        }

        .admin-user-info span {
            font-size: 0.75rem;
            color: #6c757d;
        }

        .admin-content {
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }
        
        /* ── Dashboard & Table ──────────────── */
        .dashboard-title {
            color: #e91e63;
            font-weight: 800;
            font-size: 1.75rem;
            text-transform: uppercase;
            margin-bottom: 1.5rem;
        }

        .dashboard-layout {
            display: grid;
            grid-template-columns: 1fr 320px;
            gap: 1.5rem;
            align-items: start;
        }
        
        @@media (max-width: 992px) {
            .dashboard-layout { grid-template-columns: 1fr; }
        }

        .soft-card {
            background: #fff;
            border: 1px solid #dee2e6;
            border-radius: 8px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.02);
            padding: 1.5rem;
            text-align: center;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            transition: transform 0.2s, box-shadow 0.2s;
        }

        .soft-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 12px rgba(0,0,0,0.04);
        }

        .soft-card-icon {
            font-size: 2.2rem;
            margin-bottom: 0.5rem;
            color: #e91e63;
        }
        .soft-card-icon.blue { color: #3498db; }
        .soft-card-icon.green { color: #2ecc71; }
        .soft-card-icon.yellow { color: #f1c40f; }

        .soft-card-value {
            font-size: 2.2rem;
            font-weight: 800;
            margin-bottom: 0.25rem;
            line-height: 1;
            color: #111;
        }

        .soft-card-label {
            font-size: 0.85rem;
            font-weight: 700;
            color: #6c757d;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        
        .quick-actions-panel {
            background: #fff;
            border: 1px solid #dee2e6;
            border-radius: 8px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.02);
            padding: 1.5rem;
        }

        .quick-actions-title {
            font-size: 1rem;
            font-weight: 800;
            color: #e91e63;
            text-transform: uppercase;
            margin-bottom: 1.25rem;
            padding-bottom: 0.75rem;
            border-bottom: 2px solid #f0f0f0;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .soft-btn {
            border: none;
            border-radius: 6px;
            font-weight: 600;
            padding: 0.75rem 1rem;
            transition: all 0.2s ease;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            cursor: pointer;
        }
        
        .soft-btn:hover { text-decoration: none; filter: brightness(0.95); color: inherit; }
        .soft-btn:active { transform: scale(0.98); }
        
        .btn-teal { background-color: #20c997; color: #fff; }
        .btn-teal:hover { color: #fff; }
        .btn-blue { background-color: #3498db; color: #fff; }
        .btn-blue:hover { color: #fff; }
        .btn-green { background-color: #2ecc71; color: #fff; }
        .btn-green:hover { color: #fff; }
        .btn-yellow { background-color: #f1c40f; color: #000; }
        .btn-yellow:hover { color: #000; }
        .btn-block { display: flex; width: 100%; margin-bottom: 0.75rem; }

        .brutalist-table-container {
            background: #fff;
            border: 1px solid #dee2e6;
            border-radius: 8px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.02);
            overflow: hidden;
            margin-top: 1rem;
        }

        .brutalist-table {
            width: 100%;
            border-collapse: collapse;
        }

        .brutalist-table th {
            background: #fff;
            border-bottom: 2px solid #dee2e6;
            padding: 1rem;
            font-weight: 700;
            font-size: 0.85rem;
            color: #333;
            text-align: left;
        }

        .brutalist-table td {
            padding: 1rem;
            border-bottom: 1px solid #f0f0f0;
            vertical-align: middle;
            font-size: 0.9rem;
        }

        .brutalist-table tr:nth-child(even) {
            background-color: #fafafa;
        }

        .status-dot {
            height: 8px;
            width: 8px;
            border-radius: 50%;
            display: inline-block;
            margin-right: 5px;
        }
        .status-active { background-color: #198754; }
        .status-done { background-color: #0d6efd; }


        .page-header {
            margin-bottom: 1.25rem;
            padding-bottom: 0.75rem;
            border-bottom: 1px solid #dee2e6;
        }

        .page-header h1 {
            font-size: 1.5rem;
            font-weight: 600;
            color: #333;
        }

        .page-header p {
            color: #6c757d;
            margin-top: 0.25rem;
            font-size: 0.875rem;
        }

        /* ── Cards ────────────────────────────────── */
        .card {
            background: #fff;
            border: 1px solid #dee2e6;
            border-radius: 4px;
            padding: 1.25rem;
            margin-bottom: 1rem;
        }

        /* ── Buttons ──────────────────────────────── */
        .btn {
            display: inline-flex;
            align-items: center;
            gap: 0.375rem;
            padding: 0.375rem 0.75rem;
            border-radius: 4px;
            font-size: 0.875rem;
            font-weight: 500;
            font-family: inherit;
            cursor: pointer;
            border: 1px solid transparent;
            text-decoration: none;
            line-height: 1.5;
        }

        .btn:hover { text-decoration: none; }

        .btn-primary {
            background-color: #0d6efd;
            color: #fff;
            border-color: #0d6efd;
        }
        .btn-primary:hover { background-color: #0b5ed7; border-color: #0a58ca; }

        .btn-success {
            background-color: #198754;
            color: #fff;
            border-color: #198754;
        }
        .btn-success:hover { background-color: #157347; border-color: #146c43; }

        .btn-danger {
            background-color: #dc3545;
            color: #fff;
            border-color: #dc3545;
        }
        .btn-danger:hover { background-color: #bb2d3b; border-color: #b02a37; }

        .btn-secondary {
            background-color: #6c757d;
            color: #fff;
            border-color: #6c757d;
        }
        .btn-secondary:hover { background-color: #5c636a; border-color: #565e64; }

        .btn-outline {
            background-color: transparent;
            color: #6c757d;
            border-color: #6c757d;
        }
        .btn-outline:hover { background-color: #6c757d; color: #fff; }

        .btn-error {
            background-color: #dc3545;
            color: #fff;
            border-color: #dc3545;
        }
        .btn-error:hover { background-color: #bb2d3b; }

        .btn-sm { padding: 0.25rem 0.5rem; font-size: 0.8rem; }

        /* ── Table ────────────────────────────────── */
        table { width: 100%; border-collapse: collapse; }

        th {
            text-align: left;
            padding: 0.6rem 0.75rem;
            font-size: 0.8rem;
            font-weight: 600;
            color: #495057;
            background-color: #f8f9fa;
            border-bottom: 2px solid #dee2e6;
        }

        td {
            padding: 0.6rem 0.75rem;
            border-bottom: 1px solid #dee2e6;
            font-size: 0.875rem;
            vertical-align: middle;
        }

        tr:last-child td { border-bottom: none; }
        tr:hover td { background-color: #f8f9fa; }

        /* ── Badges ───────────────────────────────── */
        .badge {
            display: inline-block;
            padding: 0.2rem 0.5rem;
            border-radius: 3px;
            font-size: 0.75rem;
            font-weight: 600;
        }

        .badge-pending { background-color: #fff3cd; color: #664d03; }
        .badge-processing { background-color: #cfe2ff; color: #084298; }
        .badge-indexed { background-color: #d1e7dd; color: #0f5132; }
        .badge-failed { background-color: #f8d7da; color: #842029; }

        /* ── Forms ────────────────────────────────── */
        .form-group { margin-bottom: 1rem; }

        .form-label {
            display: block;
            color: #333;
            font-size: 0.875rem;
            font-weight: 500;
            margin-bottom: 0.35rem;
        }

        .form-control {
            width: 100%;
            padding: 0.375rem 0.75rem;
            background-color: #fff;
            border: 1px solid #ced4da;
            border-radius: 4px;
            color: #333;
            font-size: 0.875rem;
            font-family: inherit;
            outline: none;
        }

        .form-control:focus {
            border-color: #86b7fe;
            box-shadow: 0 0 0 0.2rem rgba(13,110,253,0.25);
        }

        /* ── Alert ────────────────────────────────── */
        .alert {
            padding: 0.75rem 1rem;
            border-radius: 4px;
            margin-bottom: 1rem;
            font-size: 0.875rem;
            border: 1px solid transparent;
        }

        .alert-error { background-color: #f8d7da; border-color: #f5c2c7; color: #842029; }
        .alert-success { background-color: #d1e7dd; border-color: #badbcc; color: #0f5132; }
        .alert-info { background-color: #cff4fc; border-color: #b6effb; color: #055160; }
        .alert-warning { background-color: #fff3cd; border-color: #ffecb5; color: #664d03; }

        /* ── Grid ─────────────────────────────────── */
        .grid-2 { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem; }
        .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; }
        .grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; }

        .stat-card {
            background: #fff;
            border: 1px solid #dee2e6;
            border-radius: 4px;
            padding: 1rem;
        }

        .stat-card .stat-value {
            font-size: 1.5rem;
            font-weight: 700;
            color: #333;
            line-height: 1;
        }

        .stat-card .stat-label {
            color: #6c757d;
            font-size: 0.8rem;
            margin-top: 0.25rem;
        }

        .stat-card .stat-icon {
            font-size: 1.25rem;
            margin-bottom: 0.5rem;
        }

        /* ── Footer ───────────────────────────────── */
        .footer {
            text-align: center;
            padding: 1rem;
            font-size: 0.8rem;
            color: #6c757d;
            border-top: 1px solid #dee2e6;
            background-color: #fff;
        }

        @@media (max-width: 768px) {
            .navbar-nav { display: none; }
            .grid-2, .grid-3, .grid-4 { grid-template-columns: 1fr; }
            .main-content { padding: 1rem; }
            .admin-frame { grid-template-columns: 1fr; }
            .admin-sidebar { border-right: none; border-bottom: 1px solid #dee2e6; }
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    @{
        var activePage = ViewData["ActivePage"]?.ToString() ?? "";
        var isAdmin = User.Identity?.IsAuthenticated == true && User.IsInRole("Admin");
        var isTeacher = User.Identity?.IsAuthenticated == true && User.IsInRole("Teacher");
    }

    @if (isAdmin || isTeacher)
    {
        <div class="admin-frame">
            <aside class="admin-sidebar">
                <a href="/" class="admin-brand">🎓 EduManager</a>
                
                @if (isAdmin)
                {
                    <div class="admin-menu-label">ADMIN</div>
                    <div class="admin-menu">
                        <a href="/" class="admin-menu-link @(activePage == "Dashboard" ? "active" : "")">
                            <span>📊</span> TỔNG QUAN
                        </a>
                        <a href="/Admin/Users" class="admin-menu-link @(activePage == "Users" ? "active" : "")">
                            <span>👥</span> QUẢN LÝ NGƯỜI DÙNG
                        </a>
                        <a href="/Subjects" class="admin-menu-link @(activePage == "Subjects" ? "active" : "")">
                            <span>📖</span> QUẢN LÝ MÔN HỌC
                        </a>
                        <a href="#" class="admin-menu-link @(activePage == "Subscribers" ? "active" : "")">
                            <span>📝</span> NGƯỜI ĐĂNG KÝ
                        </a>
                        <a href="#" class="admin-menu-link @(activePage == "Packages" ? "active" : "")">
                            <span>👑</span> GÓI HỘI VIÊN
                        </a>
                    </div>
                }
                else if (isTeacher)
                {
                    <div class="admin-menu-label">GIẢNG VIÊN</div>
                    <div class="admin-menu">
                        <a href="/Subjects?filter=mine" class="admin-menu-link @(activePage == "MySubjects" ? "active" : "")">
                            <span>🧑‍🏫</span> MÔN PHỤ TRÁCH
                        </a>
                        <a href="/Subjects?filter=all" class="admin-menu-link @(activePage == "Subjects" ? "active" : "")">
                            <span>📖</span> TẤT CẢ MÔN HỌC
                        </a>
                        <a href="/Documents" class="admin-menu-link @(activePage == "Documents" ? "active" : "")">
                            <span>📄</span> TÀI LIỆU CỦA TÔI
                        </a>
                    </div>
                }
                
                <div style="flex-grow: 1;"></div>

                <div class="admin-user-box">
                    <div class="admin-user-avatar">
                        👤
                    </div>
                    <div class="admin-user-info">
                        <strong>@(User.FindFirst("FullName")?.Value ?? User.Identity?.Name ?? (isAdmin ? "admin" : "lecturer"))</strong>
                        <span>@(isAdmin ? "ADMIN" : "LECTURER")</span>
                    </div>
                </div>
                <form method="post" action="/Auth/Logout" style="margin:0;">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn-logout" style="width:100%; border-radius: 6px; padding: 0.5rem; background-color: #fff; border: 1px solid #dee2e6; color: #333; font-weight: 600;">Đăng xuất</button>
                </form>
            </aside>
            <div class="admin-content">
                <main class="main-content">
                    @RenderBody()
                </main>
            </div>
        </div>
    }
    else
    {
    <nav class="navbar">
        <a href="/Subjects" class="navbar-brand">RAG LMS</a>

        <div class="navbar-nav">
            <a href="/Subjects" class="nav-link @(ViewData["ActivePage"]?.ToString() == "Subjects" ? "active" : "")">
                Môn học
            </a>
            @if (!User.IsInRole("Student"))
            {
                <a href="/Documents" class="nav-link @(ViewData["ActivePage"]?.ToString() == "Documents" ? "active" : "")">
                    Tài liệu
                </a>
            }
            <a href="/Chat" class="nav-link @(ViewData["ActivePage"]?.ToString() == "Chat" ? "active" : "")">
                Chat RAG
            </a>

            @if (!User.IsInRole("Student"))
            {
                <a href="/Benchmark" class="nav-link @(ViewData["ActivePage"]?.ToString() == "Benchmark" ? "active" : "")">
                    Benchmark
                </a>
            }

            @if (User.IsInRole("Admin"))
            {
                <div class="nav-separator"></div>
                <a href="/Admin/Users" class="nav-link @(ViewData["ActivePage"]?.ToString() == "Users" ? "active" : "")">
                    Người dùng
                </a>
                <a href="/Admin/Models" class="nav-link @(ViewData["ActivePage"]?.ToString() == "Models" ? "active" : "")">
                    AI Models
                </a>
            }
        </div>

        <div class="navbar-right">
            <a href="/Profile" class="user-info-text" style="text-decoration:none;">
                <strong>@User.FindFirst("FullName")?.Value</strong>
                <span class="badge-role badge-@(User.IsInRole("Admin") ? "admin" : User.IsInRole("Teacher") ? "teacher" : "student")">
                    @User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value
                </span>
            </a>
            <form method="post" action="/Auth/Logout" style="margin:0;">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn-logout">Đăng xuất</button>
            </form>
        </div>
    </nav>

    <main class="main-content">
        @RenderBody()
    </main>

    <footer class="footer">
        &copy; 2024 PRN222 Assignment 2 — RAG Learning Management System
    </footer>
    }

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>