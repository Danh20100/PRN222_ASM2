@page "/Subjects/{id:int}"
@model PRN222_Assignment2.Pages.Subjects.DetailsModel
@{
    ViewData["Title"] = Model.Subject?.SubjectName ?? "Chi tiết môn học";
    ViewData["ActivePage"] = "Subjects";
}

@if (Model.Subject == null)
{
    <div class="alert alert-error">Môn học không tồn tại.</div>
    return;
}

<!-- Page Header -->
<a href="/Subjects" class="subject-back-link"><i class="bi bi-arrow-left"></i> Quay lại môn phụ trách</a>

<div class="subject-header-row">
    <div>
        <h1 class="subject-title">[@Model.Subject.SubjectCode] @Model.Subject.SubjectName</h1>
        <p class="subject-subtitle">Quản lý cấu trúc chương học và tài liệu</p>
    </div>
    <div class="subject-actions-row">
        <a href="#" class="btn-history"><i class="bi bi-clock-history"></i> Lịch sử</a>
        @if (Model.CanEdit)
        {
            <button class="btn-add-chapter" onclick="showCreateModal()"><i class="bi bi-plus-lg"></i> Thêm chương</button>
            <button class="btn-upload" onclick="showUploadModal()"><i class="bi bi-upload"></i> Tải tài liệu</button>
        }
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success" style="margin-bottom:1rem;">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-error" style="margin-bottom:1rem;">@TempData["Error"]</div>
}

<!-- Chapters -->
@foreach (var ch in Model.Chapters.OrderBy(c => c.OrderIndex))
{
    <div class="chapter-card">
        <!-- Chapter Header -->
        <div class="chapter-header">
            <h3 class="chapter-title">Chương @ch.OrderIndex: @ch.ChapterName</h3>
            @if (Model.CanEdit)
            {
                <div class="chapter-actions">
                    <button class="btn-edit-chapter"><i class="bi bi-pencil"></i> Sửa</button>
                    <form method="post" asp-page-handler="DeleteChapter" asp-route-id="@Model.Subject.SubjectId"
                          onsubmit="return confirm('Bạn có chắc chắn muốn xóa chương này?');" style="margin:0;">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="chapterId" value="@ch.ChapterId" />
                        <button type="submit" class="btn-delete-chapter"><i class="bi bi-trash"></i> Xóa</button>
                    </form>
                </div>
            }
        </div>

        <hr class="chapter-divider" />

        <!-- Documents -->
        <div class="doc-list">
            @foreach (var doc in ch.Documents.OrderByDescending(d => d.UploadedAt))
            {
                <div class="doc-item">
                    <div class="doc-info">
                        <div class="doc-name">
                            <span class="doc-badge">[@(doc.FileType?.ToUpper() ?? "FILE")]</span>
                            @doc.OriginalFileName
                        </div>
                        <div class="doc-meta">
                            <span><i class="bi bi-person"></i> Upload bởi: <strong>@doc.UploadedByFullName</strong></span>
                            <span><i class="bi bi-clock"></i> @doc.UploadedAt.ToString("dd/MM/yyyy HH:mm")</span>
                            <span class="doc-status doc-status--@doc.Status.ToLower()">@doc.Status@(doc.TotalChunks.HasValue && doc.Status == "Indexed" ? $" ({doc.TotalChunks} chunks)" : "")</span>
                        </div>
                    </div>
                    <div class="doc-actions">
                        @if (doc.Status == "Indexed")
                        {
                            <a href="/Documents/Details/@doc.DocumentId" class="doc-action-chunk"><i class="bi bi-diagram-3"></i> Chunks (@doc.TotalChunks)</a>
                        }
                        else if (doc.Status == "Failed" && !string.IsNullOrEmpty(doc.ErrorMessage))
                        {
                            <span class="doc-error-hint" title="@doc.ErrorMessage"><i class="bi bi-exclamation-triangle"></i> Lỗi embed</span>
                        }
                        <a href="/Documents/View/@doc.DocumentId" class="doc-action-view"><i class="bi bi-eye"></i> Xem</a>
                        <a href="/Documents/Download/@doc.DocumentId" class="doc-action-dl"><i class="bi bi-download"></i> Tải</a>
                        @if (Model.CanEdit)
                        {
                            <form method="post" asp-page-handler="Chunk" asp-route-id="@Model.Subject.SubjectId" style="margin:0;">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="documentId" value="@doc.DocumentId" />
                                <button type="submit" class="doc-action-chunk"><i class="bi bi-arrow-repeat"></i> Chunk & Embed</button>
                            </form>
                            <form method="post" asp-page-handler="DeleteDoc" asp-route-id="@Model.Subject.SubjectId"
                                  onsubmit="return confirm('Xóa tài liệu này?');" style="margin:0;">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="documentId" value="@doc.DocumentId" />
                                <button type="submit" class="doc-action-delete"><i class="bi bi-trash"></i> Xóa</button>
                            </form>
                        }
                    </div>
                </div>
            }
            @if (!ch.Documents.Any())
            {
                <div class="empty-chapter">Chưa có tài liệu nào trong chương này.</div>
            }
        </div>
    </div>
}

@if (!Model.Chapters.Any())
{
    <div class="empty-state-box">
        <div style="font-size:2.5rem; margin-bottom:0.75rem;"><i class="bi bi-folder2"></i></div>
        <div style="font-weight:900; text-transform:uppercase;">Chưa có chương học nào.</div>
        @if (Model.CanEdit)
        {
            <button class="btn-add-chapter" style="margin-top:1rem;" onclick="showCreateModal()"><i class="bi bi-plus-lg"></i> Thêm chương đầu tiên</button>
        }
    </div>
}

@if (Model.CanEdit)
{
    <!-- Create Chapter Modal -->
    <div id="create-modal" class="modal-overlay">
        <div class="modal-content">
            <h3 class="modal-title"><i class="bi bi-plus-lg"></i> Thêm chương học mới</h3>
            <form method="post" asp-page-handler="CreateChapter" asp-route-id="@Model.Subject.SubjectId">
                @Html.AntiForgeryToken()
                <div class="form-group" style="margin-bottom:0.75rem;">
                    <label class="form-label" style="font-weight:700;">Tên chương</label>
                    <input type="text" asp-for="NewChapter.ChapterName" class="form-control" required placeholder="Ví dụ: Entity Framework Core" />
                </div>
                <div class="form-group" style="margin-bottom:0.75rem;">
                    <label class="form-label" style="font-weight:700;">Số thứ tự</label>
                    <input type="number" asp-for="NewChapter.OrderIndex" class="form-control" value="@(Model.Chapters.Count() + 1)" required />
                </div>
                <div class="form-group" style="margin-bottom:1.25rem;">
                    <label class="form-label" style="font-weight:700;">Mô tả (tùy chọn)</label>
                    <textarea asp-for="NewChapter.Description" class="form-control" rows="3"></textarea>
                </div>
                <div style="display:flex; gap:0.5rem; justify-content:flex-end;">
                    <button type="button" class="btn btn-secondary" onclick="hideCreateModal()">Huỷ</button>
                    <button type="submit" class="btn-add-chapter">Tạo mới</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Upload Document Modal -->
    <div id="upload-modal" class="modal-overlay">
        <div class="modal-content">
            <h3 class="modal-title"><i class="bi bi-upload"></i> Tải tài liệu lên</h3>
            <form method="post" enctype="multipart/form-data" asp-page-handler="UploadDocument" asp-route-id="@Model.Subject.SubjectId">
                @Html.AntiForgeryToken()
                <div class="form-group" style="margin-bottom:0.75rem;">
                    <label class="form-label" style="font-weight:700;">Chương học</label>
                    <select name="chapterId" class="form-control" required>
                        <option value="">-- Chọn chương --</option>
                        @foreach (var c in Model.Chapters.OrderBy(x => x.OrderIndex))
                        {
                            <option value="@c.ChapterId">Chương @c.OrderIndex: @c.ChapterName</option>
                        }
                    </select>
                </div>
                <div class="form-group" style="margin-bottom:0.75rem;">
                    <label class="form-label" style="font-weight:700;">File (.pdf, .docx, .txt)</label>
                    <input type="file" name="uploadFile" class="form-control" accept=".pdf,.txt,.docx" required />
                    <small class="form-hint">Sau khi upload, hệ thống tự động chunk & embed (có thể mất vài giây).</small>
                </div>
                <div class="form-group" style="margin-bottom:0.75rem;">
                    <label class="form-label" style="font-weight:700;">Embedding Model</label>
                    <select name="embeddingModelId" class="form-control" required>
                        @foreach (var m in Model.EmbeddingModels.Where(x => x.IsActive))
                        {
                            if (m.IsDefault)
                            {
                                <option value="@m.EmbeddingModelId" selected>@m.ModelName (@m.Provider)</option>
                            }
                            else
                            {
                                <option value="@m.EmbeddingModelId">@m.ModelName (@m.Provider)</option>
                            }
                        }
                    </select>
                </div>
                <div class="form-group" style="margin-bottom:1.25rem;">
                    <label class="form-label" style="font-weight:700;">Chunking Strategy</label>
                    <select name="chunkingStrategyId" class="form-control" required>
                        @foreach (var s in Model.ChunkingStrategies)
                        {
                            if (s.IsDefault)
                            {
                                <option value="@s.ChunkingStrategyId" selected>@s.StrategyName — @s.ChunkSize từ/chunk, overlap @s.ChunkOverlap</option>
                            }
                            else
                            {
                                <option value="@s.ChunkingStrategyId">@s.StrategyName — @s.ChunkSize từ/chunk, overlap @s.ChunkOverlap</option>
                            }
                        }
                    </select>
                </div>
                <div style="display:flex; justify-content:flex-end; gap:0.5rem;">
                    <button type="button" class="btn btn-secondary" onclick="hideUploadModal()">Huỷ</button>
                    <button type="submit" class="btn-upload"><i class="bi bi-lightning"></i> Upload & Chunk</button>
                </div>
            </form>
        </div>
    </div>

    @section Scripts {
        <script>
            function showCreateModal() { document.getElementById('create-modal').classList.add('show'); }
            function hideCreateModal() { document.getElementById('create-modal').classList.remove('show'); }
            document.getElementById('create-modal').addEventListener('click', function(e) { if (e.target === this) hideCreateModal(); });

            function showUploadModal() { document.getElementById('upload-modal').classList.add('show'); }
            function hideUploadModal() { document.getElementById('upload-modal').classList.remove('show'); }
            document.getElementById('upload-modal').addEventListener('click', function(e) { if (e.target === this) hideUploadModal(); });
        </script>
    }
}
